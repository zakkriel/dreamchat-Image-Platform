# Image Platform Playground — local dev config (Vite reads VITE_* at dev-server start).
# Copy to `.env` and adjust if your API is not on the default address.

# Where the Vite dev proxy forwards `/api/*` requests. This is the local API
# address. The backend has no CORS, so browser calls go through this proxy.
VITE_API_TARGET=http://localhost:8080
