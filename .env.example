APP_PORT=8080
ENVIRONMENT=dev
LOG_LEVEL=info
WORKER_CONCURRENCY=4

# Phase 7C-3 RLS / tenant isolation. Two DSNs:
#   POSTGRES_DSN        - the tenant pool. In PRODUCTION point this at the
#                         RLS-enforced, non-superuser role (image_platform_api),
#                         which is subject to row-level security.
#   POSTGRES_SYSTEM_DSN - the system pool (BYPASSRLS role image_platform_system),
#                         used for pre-tenant auth lookups, the worker, the system
#                         cost lifecycle, and explicit admin cross-tenant ops.
# Both roles + grants are created by migrations/0009_rls_tenant_isolation.up.sql
# (override the dev passwords there in production). Locally both may point at the
# superuser image_platform role (it bypasses RLS), as this example does;
# POSTGRES_SYSTEM_DSN falls back to POSTGRES_DSN when unset.
POSTGRES_DSN=postgres://image_platform:image_platform@localhost:5432/image_platform?sslmode=disable
POSTGRES_SYSTEM_DSN=postgres://image_platform:image_platform@localhost:5432/image_platform?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

S3_BUCKET=image-platform
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_PATH_STYLE=true
# How long presigned read URLs stay valid (Phase 6B delivery). Go duration.
S3_PRESIGN_TTL=15m

IMAGE_PROVIDER=mock
BFL_API_KEY=

API_TOKEN_PEPPER=dev-pepper-change-me
OPENAPI_DOCS_ENABLED=true
